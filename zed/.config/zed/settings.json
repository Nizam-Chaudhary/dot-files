{
  "context_servers": {
    "mcp-server-context7": {
      "enabled": true,
      "settings": {
        "context7_api_key": ""
      }
    }
  },
  "edit_predictions": {
    "enabled_in_text_threads": true,
    "mode": "eager",
  },
  "disable_ai": false,
  "git": {
    "inline_blame": {
      "show_commit_summary": false,
    },
    "gutter_debounce": 0,
    "git_gutter": "tracked_files",
  },
  "active_pane_modifiers": {
    "border_size": 1.0,
  },
  "window_decorations": "client",
  "use_system_window_tabs": false,
  "bottom_dock_layout": "contained",
  "preview_tabs": {
    "enabled": true,
  },
  "tab_bar": {
    "show_nav_history_buttons": false,
  },
  "tabs": {
    "show_close_button": "hover",
    "show_diagnostics": "off",
    "close_position": "right",
    "file_icons": true,
    "git_status": true,
  },
  "title_bar": {
    "show_menus": false,
    "show_user_picture": true,
    "show_user_menu": true,
    "show_onboarding_banner": true,
    "show_project_items": true,
    "show_branch_name": true,
    "show_branch_icon": true,
  },
  "debugger": {
    "dock": "bottom",
    "button": true,
  },
  "status_bar": {
    "cursor_position_button": true,
    "active_language_button": true,
  },
  "file_finder": {
    "git_status": true,
    "modal_max_width": "large",
  },
  "seed_search_query_from_cursor": "selection",
  "search": {
    "button": false,
    "center_on_match": false,
    "regex": false,
  },
  "use_smartcase_search": false,
  "diagnostics": {
    "button": true,
    "inline": {
      "update_debounce_ms": 100,
      "enabled": true,
    },
    "include_warnings": false,
  },
  "colorize_brackets": true,
  "lsp_document_colors": "inlay",
  "show_completions_on_input": true,
  "show_whitespaces": "selection",
  "tab_size": 2,
  "toolbar": {
    "code_actions": false,
    "selections_menu": true,
    "quick_actions": true,
    "breadcrumbs": true,
  },
  "minimap": {
    "max_width_columns": 80,
    "thumb_border": "full",
    "display_in": "active_editor",
    "show": "auto",
  },
  "scrollbar": {
    "show": "auto",
  },
  "gutter": {
    "runnables": true,
    "line_numbers": true,
  },
  "show_signature_help_after_edits": true,
  "auto_signature_help": false,
  "autoscroll_on_clicks": true,
  "fast_scroll_sensitivity": 5.0,
  "scroll_sensitivity": 2.0,
  "hide_mouse": "on_typing",
  "cursor_shape": "block",
  "agent_buffer_font_size": 14.0,
  "agent_ui_font_size": 18.0,
  "buffer_line_height": {
    "custom": 1.6,
  },
  "buffer_font_weight": 400.0,
  "redact_private_values": false,
  "use_system_prompts": false,
  "use_system_path_prompts": false,
  "format_on_save": "off",
  "icon_theme": "Material Icon Theme",
  "show_edit_predictions": true,
  "features": {
    "edit_prediction_provider": "copilot",
  },
  "formatter": "language_server",
  "ui_font_size": 20,
  "buffer_font_size": 20,
  "ui_font_family": "CaskaydiaCove Nerd Font Mono",
  "buffer_font_family": "CaskaydiaCove Nerd Font Mono",
  // "buffer_font_features": {
  //   "calt": true,
  //   "cv01": 1,
  //   "cv31": 1,
  //   "liga": true,
  //   "ss01": true,
  //   "ss02": true,
  //   "ss03": true,
  //   "ss04": true,
  //   "ss05": true,
  //   "ss06": true,
  //   "ss07": true,
  //   "ss08": true,
  //   "ss09": true
  // },
  // Use zed commit editor
  "terminal": {
    "font_weight": 400.0,
    "shell": "system",
    "dock": "bottom",
    "button": true,
    "env": {
      "EDITOR": "zed --wait",
    },
    "font_size": 17.0,
    "font_family": "CaskaydiaCove Nerd Font Mono",
  },
  "theme": {
    "mode": "dark",
    "light": "Kanagawa",
    "dark": "Kanagawa",
  },
  "base_keymap": "VSCode",
  // Vim mode settings
  "vim_mode": false,
  // use relative line numbers
  "relative_line_numbers": "disabled",
  // Indentation, rainbow indentation
  "indent_guides": {
    "background_coloring": "disabled",
    "enabled": true,
    "coloring": "indent_aware",
    "active_line_width": 2,
    "line_width": 1,
  },
  // Use Copilot Chat AI as default
  "agent": {
    "always_allow_tool_actions": true,
    "dock": "right",
    "default_profile": "write",
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "gpt-4.1",
    },
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-4.1",
    },
  },
  // Inlay hints preconfigured by Zed: Go, Rust, Typescript and Svelte
  "inlay_hints": {
    "enabled": false,
  },
  // LSP
  "lsp": {
    "tailwindcss-language-server": {
      "settings": {
        "classAttributes": ["class", "className", "ngClass", "styles"],
      },
    },
    "biome": {
      "settings": {
        "require_config_file": true,
      },
    },
  },
  "languages": {
    "JavaScript": {
      "formatter": "prettier",
      "language_servers": ["!vtsls", "!typescript-language-server", "tsgo", "..."],
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
    },
    "TypeScript": {
      "formatter": "prettier",
      "language_servers": ["!vtsls", "!typescript-language-server", "tsgo", "..."],
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
    },
    "TSX": {
      "formatter": "prettier",
      "language_servers": ["!vtsls", "!typescript-language-server", "tsgo", "..."],
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
    },
    "JSON": {
      "formatter": "prettier",
    },
    "JSONC": {
      "formatter": "prettier",
    },
    "CSS": {
      "formatter": "prettier",
    },
    "GraphQL": {
      "formatter": "prettier",
    },
    "Markdown": {
      "formatter": "prettier",
    },
    "YAML": {
      "formatter": "prettier",
    },
    "HTML": {
      "formatter": "prettier",
    },
  },
  // File syntax highlighting
  "file_types": {
    "Dockerfile": ["Dockerfile", "Dockerfile.*"],
    "JSON": ["json", "jsonc", "*.code-snippets"],
  },
  // File scan exclusions, hide on the file explorer and search
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    // above is default from Zed
    "**/out",
    "**/.turbo",
    "**/.vscode-test",
    "**/.next",
    "**/.storybook",
    "**/.tap",
    "**/.nyc_output",
    "**/report",
  ],
  // Turn off telemetry
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  // Move all panel to the right
  "project_panel": {
    "sort_mode": "directories_first",
    "hide_hidden": false,
    "hide_root": false,
    "sticky_scroll": true,
    "indent_size": 20.0,
    "folder_icons": true,
    "file_icons": true,
    "entry_spacing": "comfortable",
    "button": true,
    "dock": "left",
    "git_status": true,
    "default_width": 360,
  },
  "outline_panel": {
    "button": true,
    "dock": "right",
    "default_width": 360,
  },
  "git_panel": {
    "status_style": "label_color",
    "button": true,
    "sort_by_path": false,
    "tree_view": true,
    "dock": "right",
    "default_width": 360,
  },
  "collaboration_panel": {
    "dock": "left",
    "button": false,
  },
  // Move some unnecessary panels to the left
  "notification_panel": {
    "button": false,
    "dock": "left",
  },

  "prettier": {
    "allowed": true,
    "plugins": [
      "prettier-plugin-organize-imports",
      "prettier-plugin-tailwindcss",
    ],
    "arrowParens": "always",
    "tabWidth": 2,
  },
  "remove_trailing_whitespace_on_save": true,

  "auto_install_extensions": {
    "basher": true,
    "biome": true,
    "caddyfile": true,
    "comment": true,
    "docker-compose": true,
    "dockerfile": true,
    "env": true,
    "git-firefly": true,
    "github-actions": true,
    "tsgo": true,
    // "gruvbox-material": true,
    "kanagawa-themes": true,
    "html": true,
    "ini": true,
    "log": true,
    "make": true,
    "material-icon-theme": true,
    "mcp-server-context7": true,
    "mdx": true,
    "nginx": true,
    "prisma": true,
    "rainbow-csv": true,
    "sql": true,
    "terraform": true,
    "toml": true,
    "graphql": true
  },
}
