  "themes": {},
  "icon_themes": {
    "Material Icon Theme": {
      "extension": "material-icon-theme",
      "path": "icon_themes/material-icon-theme.json"
    }
  },
  "languages": {
    "Dockerfile": {
      "extension": "dockerfile",
      "path": "languages/dockerfile",
      "matcher": {
        "path_suffixes": ["Dockerfile", "Containerfile", "dockerfile"],
        "first_line_pattern": null
      },
      "hidden": false,
      "grammar": "dockerfile"
    },
    "Git Attributes": {
      "extension": "git-firefly",
      "path": "languages/gitattributes",
      "matcher": {
        "path_suffixes": ["gitattributes", ".gitattributes"],
        "first_line_pattern": null
      },
      "hidden": false,
      "grammar": "gitattributes"
    },
    "Git Commit": {
      "extension": "git-firefly",
      "path": "languages/gitcommit",
      "matcher": {
        "path_suffixes": [
          "COMMIT_EDITMSG",
          "EDIT_DESCRIPTION",
          "MERGE_MSG",
          "NOTES_EDITMSG",
          "TAG_EDITMSG"
        ],
        "first_line_pattern": null
      },
      "hidden": false,
      "grammar": "git_commit"
    },
    "Git Config": {
      "extension": "git-firefly",
      "path": "languages/gitconfig",
      "matcher": {
        "path_suffixes": [
          "config.worktree",
          ".gitconfig",
          ".gitmodules",
          ".lfsconfig"
        ],
        "first_line_pattern": null
      },
      "hidden": false,
      "grammar": "git_config"
    },
    "Git Ignore": {
      "extension": "git-firefly",
      "path": "languages/gitignore",
      "matcher": {
        "path_suffixes": [
          ".containerignore",
          ".cursorignore",
          ".dockerignore",
          ".eslintignore",
          ".fdignore",
          ".gitignore",
          ".git-blame-ignore-revs",
          ".ignore",
          ".npmignore",
          ".prettierignore",
          ".rgignore",
          ".vscodeignore"
        ],
        "first_line_pattern": null
      },
      "hidden": false,
      "grammar": "gitignore"
    },
    "Git Rebase": {
      "extension": "git-firefly",
      "path": "languages/gitrebase",
      "matcher": {
        "path_suffixes": ["git-rebase-todo"],
        "first_line_pattern": null
      },
      "hidden": false,
      "grammar": "git_rebase"
    },
    "GraphQL": {
      "extension": "graphql",
      "path": "languages/graphql",
      "matcher": {
        "path_suffixes": ["graphql", "gql", "graphqls"],
        "first_line_pattern": null
      },
      "hidden": false,
      "grammar": "graphql"
    },
    "HCL": {
      "extension": "terraform",
      "path": "languages/hcl",
      "matcher": {
        "path_suffixes": ["hcl"],
        "first_line_pattern": null
      },
      "hidden": false,
      "grammar": "hcl"
    },
    "HTML": {
      "extension": "html",
      "path": "languages/html",
      "matcher": {
        "path_suffixes": ["html", "htm", "shtml"],
        "first_line_pattern": null
      },
      "hidden": false,
      "grammar": "html"
    },
    "LOG": {
      "extension": "log",
      "path": "languages/log",
      "matcher": {
        "path_suffixes": ["log"],
        "first_line_pattern": null
      },
      "hidden": false,
      "grammar": "log"
    },
    "SQL": {
      "extension": "sql",
      "path": "languages/sql",
      "matcher": {
        "path_suffixes": ["sql"],
        "first_line_pattern": null
      },
      "hidden": false,
      "grammar": "sql"
    },
    "TOML": {
      "extension": "toml",
      "path": "languages/toml",
      "matcher": {
        "path_suffixes": ["Cargo.lock", "toml", "Pipfile", "uv.lock"],
        "first_line_pattern": null
      },
      "hidden": false,
      "grammar": "toml"
    },
    "Terraform": {
      "extension": "terraform",
      "path": "languages/terraform",
      "matcher": {
        "path_suffixes": ["tf", "tofu"],
        "first_line_pattern": null
      },
      "hidden": false,
      "grammar": "hcl"
    },
    "Terraform Vars": {
      "extension": "terraform",
      "path": "languages/terraform-vars",
      "matcher": {
        "path_suffixes": ["tfvars"],
        "first_line_pattern": null
      },
      "hidden": false,
      "grammar": "hcl"
    },
    "env": {
      "extension": "env",
      "path": "languages/env",
      "matcher": {
        "path_suffixes": ["conf", "env", "envrc", "example", "local"],
        "first_line_pattern": null
      },
      "hidden": false,
      "grammar": "env"
    }
  }
